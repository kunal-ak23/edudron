{
  "services": {
    "gateway": {
      "port": 8080,
      "cpu": "1.0",
      "memory": "2.0Gi",
      "minReplicas": 2,
      "maxReplicas": 10,
      "ingressExternal": true,
      "healthProbePath": "/actuator/health",
      "scaleRules": {
        "http": {
          "name": "http-scaler",
          "concurrentRequests": 30
        }
      },
      "environmentVariables": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "production"
        },
        {
          "name": "GATEWAY_SERVICE_PORT",
          "value": "8080"
        }
      ]
    },
    "core-api": {
      "port": 8085,
      "cpu": "1.0",
      "memory": "2.0Gi",
      "minReplicas": 1,
      "maxReplicas": 5,
      "ingressExternal": false,
      "healthProbePath": "/actuator/health",
      "scaleRules": {
        "http": {
          "name": "http-scaler",
          "concurrentRequests": 30
        }
      },
      "environmentVariables": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "production"
        },
        {
          "name": "CORE_API_SERVICE_PORT",
          "value": "8085"
        },
        {
          "name": "JWT_EXPIRATION",
          "value": "86400"
        },
        {
          "name": "JWT_REFRESH_EXPIRATION",
          "value": "604800"
        }
      ]
    },
    "content": {
      "port": 8082,
      "cpu": "2.0",
      "memory": "4.0Gi",
      "minReplicas": 1,
      "maxReplicas": 5,
      "ingressExternal": false,
      "healthProbePath": "/actuator/health",
      "scaleRules": {
        "http": {
          "name": "http-scaler",
          "concurrentRequests": 30
        }
      },
      "environmentVariables": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "production"
        },
        {
          "name": "CONTENT_SERVICE_PORT",
          "value": "8082"
        }
      ]
    }
  }
}


